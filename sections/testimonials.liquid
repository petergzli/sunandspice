
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} spacing-style {% if section.settings.color_scheme != blank %}color-{{ section.settings.color_scheme }}{% endif %}"
  style="{% render 'spacing-padding', settings: section.settings %}"
>
  {% if section.settings.heading != blank %}
    <h2 class="testimonials__heading">{{ section.settings.heading }}</h2>
  {% endif %}
  <div class="testimonials__grid">
    {% for block in section.blocks %}
      <div class="testimonials__card" {{ block.shopify_attributes }}>
        {% if block.settings.avatar != blank %}
          <div class="testimonials__avatar">
            <img
              src="{{ block.settings.avatar | image_url: width: 150 }}"
              alt="{{ block.settings.author | default: 'Customer' }}"
              width="56"
              height="56"
              loading="lazy"
            >
          </div>
        {% endif %}
        <div class="testimonials__stars">
          {% assign star_count = block.settings.stars %}
          {% for i in (1..star_count) %}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" aria-hidden="true">
              <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/>
            </svg>
          {% endfor %}
        </div>
        <p class="testimonials__quote">"{{ block.settings.quote }}"</p>
        <p class="testimonials__author">— {{ block.settings.author }}</p>
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .testimonials__heading {
    font-family: var(--font-heading--family);
    font-size: 1.75rem;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 40px;
    font-weight: 400;
    line-height: 1.2;
  }
  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .testimonials__card {
    text-align: center;
    padding: 32px 24px;
  }
  .testimonials__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto 12px;
  }
  .testimonials__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .testimonials__stars {
    display: flex;
    justify-content: center;
    gap: 2px;
    margin-bottom: 16px;
    color: var(--color-foreground-heading, #c6a1cf);
  }
  .testimonials__quote {
    font-family: var(--font-body--family);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0 0 16px;
    font-style: italic;
  }
  .testimonials__author {
    font-family: var(--font-body--family);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0;
  }
  @media (max-width: 749px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .testimonials__card {
      padding: 24px 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar"
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "category": "t:categories.social_proof",
      "blocks": [
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
